# Supabase Project URL, e.g. https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key. Do not use a service-role key in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Postgres connection string used by Drizzle/server DB access.
# Include password and sslmode=require when required by Supabase.
DATABASE_URL=
